<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============ BUTTONS ============ -->

    <!-- Primary action: log in, sign up, save, add comment -->
    <style name="Widget.TAAM.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/cinnabar</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Admin-only action: add artifact, edit artifact -->
    <style name="Widget.TAAM.Button.Admin" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/antique_gold</item>
        <item name="android:textColor">@color/ink</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Destructive action: delete artifact, delete comment -->
    <style name="Widget.TAAM.Button.Delete" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/cinnabar</item>
        <item name="strokeColor">@color/cinnabar</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Secondary / cancel: borderless -->
    <style name="Widget.TAAM.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/muted_taupe</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Artifact card in the home RecyclerView -->
    <style name="Widget.TAAM.Card.Artifact" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/silk</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">12dp</item>
        <item name="strokeColor">@color/border_tan</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Artifact name / screen titles -->
    <style name="TextAppearance.TAAM.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Field labels -->
    <style name="TextAppearance.TAAM.Label" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/muted_taupe</item>
    </style>

    <!-- Body text -->
    <style name="TextAppearance.TAAM.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/ink</item>
    </style>

    <!-- Secondary text -->
    <style name="TextAppearance.TAAM.Secondary" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/muted_taupe</item>
    </style>

</resources>