<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.TAAM.Card.Artifact"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textArtifactName"
            style="@style/TextAppearance.TAAM.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_artifact_name" />

        <TextView
            android:id="@+id/textLotNumber"
            style="@style/TextAppearance.TAAM.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_lot_number" />

        <TextView
            android:id="@+id/textCategory"
            style="@style/TextAppearance.TAAM.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_category" />

        <TextView
            android:id="@+id/textMaterial"
            style="@style/TextAppearance.TAAM.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_material" />

        <TextView
            android:id="@+id/textDynasty"
            style="@style/TextAppearance.TAAM.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_dynasty" />

        <TextView
            android:id="@+id/textDescription"
            style="@style/TextAppearance.TAAM.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="@string/placeholder_description" />

        <Button
            android:id="@+id/buttonReadMore"
            style="@style/Widget.TAAM.Button.Admin"
            android:layout_width="144dp"
            android:layout_height="wrap_content"
            android:text="@string/read_more" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>